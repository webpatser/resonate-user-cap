{
    "name": "webpatser/resonate-user-cap",
    "description": "Per-user connection cap for Resonate: cluster-wide limit on tabs and devices per user",
    "keywords": ["resonate", "websockets", "presence", "rate-limit", "cap", "broadcasting"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Christoph Kempen",
            "email": "christoph@downsized.nl"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/contracts": "^13.0",
        "illuminate/support": "^13.0",
        "webpatser/fledge-fiber": "^13.4",
        "webpatser/resonate": "^0.4"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "predis/predis": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "Webpatser\\ResonateUserCap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webpatser\\ResonateUserCap\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webpatser\\ResonateUserCap\\UserCapServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
